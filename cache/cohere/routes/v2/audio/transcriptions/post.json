{
  "description": "Transcribe an audio file.",
  "operationId": "create-transcription",
  "requestBody": {
    "content": {
      "multipart/form-data": {
        "schema": {
          "properties": {
            "file": {
              "description": "The audio file object to transcribe. Supported file extensions are flac, mp3, mpeg, mpga, ogg, and wav.",
              "format": "binary",
              "type": "string"
            },
            "language": {
              "description": "The language of the input audio, supplied in [ISO-639-1](https://en.wikipedia.org/wiki/List_of_ISO_639_language_codes) format.",
              "type": "string"
            },
            "model": {
              "description": "ID of the model to use.",
              "type": "string"
            },
            "temperature": {
              "description": "The sampling temperature, between 0 and 1. Higher values like 0.8 make the output more random, while lower values like 0.2 make it more focused and deterministic.",
              "type": "number"
            }
          },
          "required": [
            "model",
            "language",
            "file"
          ],
          "type": "object"
        }
      }
    },
    "required": true
  },
  "responses": {
    "200": {
      "content": {
        "application/json": {
          "schema": {
            "properties": {
              "text": {
                "description": "The transcribed text.",
                "type": "string"
              }
            },
            "required": [
              "text"
            ],
            "type": "object"
          }
        }
      },
      "description": "A successful response."
    },
    "400": {
      "$ref": "#/components/responses/BadRequest"
    },
    "401": {
      "$ref": "#/components/responses/Unauthorized"
    },
    "403": {
      "$ref": "#/components/responses/Forbidden"
    },
    "404": {
      "$ref": "#/components/responses/NotFound"
    },
    "422": {
