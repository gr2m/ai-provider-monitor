              },
              {
                "$ref": "#/components/schemas/BetaOverloadedError"
              }
            ],
            "title": "Error"
          },
          "request_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Request Id"
          },
          "type": {
            "const": "error",
            "default": "error",
            "title": "Type",
            "type": "string"
          }
        },
        "required": [
          "error",
          "request_id",
          "type"
        ],
        "title": "ErrorResponse",
        "type": "object"
      },
