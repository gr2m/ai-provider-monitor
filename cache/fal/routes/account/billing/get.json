          "example": {
            "credits": {
              "currency": "USD",
              "current_balance": 24.5
            },
            "username": "my-team"
          },
          "schema": {
            "description": "Account billing information with optional expanded details",
            "properties": {
              "credits": {
                "description": "Credit balance details. Only present when 'credits' is included in expand parameter.",
                "properties": {
                  "currency": {
                    "description": "Currency code for the balance",
                    "example": "USD",
                    "type": "string"
                  },
                  "current_balance": {
                    "description": "Current credit balance available on the account",
                    "example": 24.5,
                    "minimum": 0,
                    "type": "number"
                  }
                },
                "required": [
                  "current_balance",
                  "currency"
                ],
                "type": "object"
              },
              "username": {
