{
  "description": "Returns billing information for the authenticated account. Use the `expand`\nparameter to include additional details.\n\n**Expandable Fields:**\n- `credits` — Current credit balance and currency\n\n**Common Use Cases:**\n- Monitor available credit balance programmatically\n- Display balance in custom dashboards",
  "operationId": "getAccountBilling",
  "parameters": [
    {
      "description": "Data to include in the response. Use 'credits' to include current credit balance.",
      "explode": true,
      "in": "query",
      "name": "expand",
      "required": false,
      "schema": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        ],
        "description": "Data to include in the response. Use 'credits' to include current credit balance.",
        "example": "credits"
      },
      "style": "form"
    }
  ],
