{
  "operationId": "CreateVideoEdit",
  "parameters": [],
  "requestBody": {
    "content": {
      "application/json": {
        "schema": {
          "$ref": "#/components/schemas/CreateVideoEditJsonBody"
        }
      },
      "multipart/form-data": {
        "schema": {
          "$ref": "#/components/schemas/CreateVideoEditMultipartBody"
        }
      }
    }
  },
  "responses": {
    "200": {
      "content": {
        "application/json": {
          "schema": {
            "$ref": "#/components/schemas/VideoResource"
          }
        }
      },
      "description": "Success"
    }
  },
  "summary": "Create a new video generation job by editing a source video or existing generated video.",
  "tags": [
    "Videos"
  ],
  "components": {
    "schemas": {
      "CreateVideoEditJsonBody": {
        "description": "JSON parameters for editing an existing generated video.",
        "properties": {
          "prompt": {
            "description": "Text prompt that describes how to edit the source video.",
            "maxLength": 32000,
            "minLength": 1,
            "type": "string"
          },
          "video": {
            "$ref": "#/components/schemas/VideoReferenceInputParam",
            "description": "Reference to the completed video to edit."
          }
        },
        "required": [
          "video",
          "prompt"
        ],
        "title": "Create video edit JSON request",
        "type": "object"
      },
      "CreateVideoEditMultipartBody": {
        "description": "Parameters for editing an existing generated video.",
        "properties": {
          "prompt": {
            "description": "Text prompt that describes how to edit the source video.",
            "maxLength": 32000,
            "minLength": 1,
            "type": "string"
          },
          "video": {
            "oneOf": [
              {
                "description": "Reference to the completed video to edit.",
                "format": "binary",
                "type": "string"
              },
              {
                "$ref": "#/components/schemas/VideoReferenceInputParam"
              }
            ]
          }
        },
        "required": [
          "video",
          "prompt"
        ],
        "title": "Create video edit multipart request",
        "type": "object"
      },
      "VideoResource": {
        "description": "Structured information describing a generated video job.",
        "properties": {
          "completed_at": {
            "anyOf": [
              {
                "description": "Unix timestamp (seconds) for when the job completed, if finished.",
                "type": "integer"
              },
              {
                "type": "null"
              }
            ]
          },
          "created_at": {
            "description": "Unix timestamp (seconds) for when the job was created.",
            "type": "integer"
          },
          "error": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/Error-2",
                "description": "Error payload that explains why generation failed, if applicable."
              },
              {
                "type": "null"
              }
            ]
          },
          "expires_at": {
            "anyOf": [
              {
                "description": "Unix timestamp (seconds) for when the downloadable assets expire, if set.",
                "type": "integer"
              },
              {
                "type": "null"
              }
            ]
          },
          "id": {
            "description": "Unique identifier for the video job.",
            "type": "string"
          },
          "model": {
            "$ref": "#/components/schemas/VideoModel",
            "description": "The video generation model that produced the job."
          },
          "object": {
            "default": "video",
            "description": "The object type, which is always `video`.",
            "enum": [
              "video"
            ],
            "type": "string"
          },
          "progress": {
            "description": "Approximate completion percentage for the generation task.",
            "type": "integer"
          },
          "prompt": {
            "anyOf": [
              {
                "description": "The prompt that was used to generate the video.",
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "remixed_from_video_id": {
            "anyOf": [
              {
                "description": "Identifier of the source video if this video is a remix.",
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "seconds": {
            "description": "Duration of the generated clip in seconds. For extensions, this is the stitched total duration.",
            "type": "string"
          },
          "size": {
            "$ref": "#/components/schemas/VideoSize",
            "description": "The resolution of the generated video."
          },
          "status": {
            "$ref": "#/components/schemas/VideoStatus",
            "description": "Current lifecycle status of the video job."
          }
        },
        "required": [
          "id",
          "object",
          "model",
          "status",
          "progress",
          "created_at",
          "completed_at",
          "expires_at",
          "prompt",
          "size",
          "seconds",
          "remixed_from_video_id",
          "error"
        ],
        "title": "Video job",
        "type": "object"
      },
      "VideoReferenceInputParam": {
        "description": "Reference to the completed video.",
        "properties": {
          "id": {
            "description": "The identifier of the completed video.",
            "example": "video_123",
            "type": "string"
          }
        },
        "required": [
          "id"
        ],
        "type": "object"
      },
      "Error-2": {
        "description": "An error that occurred while generating the response.",
        "properties": {
          "code": {
            "description": "A machine-readable error code that was returned.",
            "type": "string"
          },
          "message": {
            "description": "A human-readable description of the error that was returned.",
            "type": "string"
          }
        },
        "required": [
          "code",
          "message"
        ],
        "title": "Error",
        "type": "object"
      },
      "VideoModel": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "enum": [
              "sora-2",
              "sora-2-pro",
              "sora-2-2025-10-06",
              "sora-2-pro-2025-10-06",
              "sora-2-2025-12-08"
            ],
            "type": "string"
          }
        ]
      },
      "VideoSize": {
        "enum": [
          "720x1280",
          "1280x720",
          "1024x1792",
          "1792x1024"
        ],
        "type": "string"
      },
      "VideoStatus": {
        "enum": [
          "queued",
          "in_progress",
          "completed",
          "failed"
        ],
        "type": "string"
      }
    }
  }
}
