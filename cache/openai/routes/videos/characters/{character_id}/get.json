{
  "operationId": "GetVideoCharacter",
  "parameters": [
    {
      "description": "The identifier of the character to retrieve.",
      "in": "path",
      "name": "character_id",
      "required": true,
      "schema": {
        "example": "char_123",
        "type": "string"
      }
    }
  ],
  "responses": {
    "200": {
      "content": {
        "application/json": {
          "schema": {
            "$ref": "#/components/schemas/VideoCharacterResource"
          }
        }
      },
      "description": "Success"
    }
  },
  "summary": "Fetch a character.",
  "tags": [
    "Videos"
  ],
  "components": {
    "schemas": {
      "VideoCharacterResource": {
        "properties": {
          "created_at": {
            "description": "Unix timestamp (in seconds) when the character was created.",
            "type": "integer"
          },
          "id": {
            "anyOf": [
              {
                "description": "Identifier for the character creation cameo.",
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "name": {
            "anyOf": [
              {
                "description": "Display name for the character.",
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "required": [
          "id",
          "name",
          "created_at"
        ],
        "type": "object"
      }
    }
  }
}
