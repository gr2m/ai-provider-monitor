      "name": "scopes",
      "required": false,
      "schema": {
        "items": {
          "$ref": "#/components/schemas/V1ProjectsProjectIdSelfHostedDistributionCredentialsPostParametersScopesSchemaItems"
        },
        "type": "array"
      }
