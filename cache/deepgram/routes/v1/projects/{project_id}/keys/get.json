      "in": "query",
      "name": "status",
      "required": false,
      "schema": {
        "$ref": "#/components/schemas/V1ProjectsProjectIdKeysGetParametersStatus"
      }
    },
    {
      "description": "Use `Authorization: Token <API_KEY>`\nExample: `Authorization: Token 12345abcdef`\n",
      "in": "header",
      "name": "Authorization",
      "required": true,
      "schema": {
        "type": "string"
      }
    }
