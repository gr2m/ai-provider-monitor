{
  "description": "Lists the features, models, tags, languages, and processing method used for requests in the specified project",
  "operationId": "list",
  "parameters": [
    {
      "in": "path",
      "name": "project_id",
      "required": true,
      "schema": {
        "type": "string"
      }
    },
    {
      "description": "Start date of the requested date range. Format accepted is YYYY-MM-DD",
      "in": "query",
      "name": "start",
      "required": false,
      "schema": {
        "format": "date",
        "type": "string"
      }
    },
    {
      "description": "End date of the requested date range. Format accepted is YYYY-MM-DD",
      "in": "query",
      "name": "end",
      "required": false,
      "schema": {
        "format": "date",
        "type": "string"
      }
    },
    {
      "description": "Use `Authorization: Token <API_KEY>`\nExample: `Authorization: Token 12345abcdef`\n",
      "in": "header",
      "name": "Authorization",
      "required": true,
      "schema": {
        "type": "string"
      }
    }
  ],
  "responses": {
    "200": {
      "content": {
        "application/json": {
          "schema": {
            "$ref": "#/components/schemas/UsageFieldsV1Response"
          }
        }
      },
      "description": "A list of fields for a specific project"
    },
    "400": {
      "content": {
        "application/json": {
          "schema": {
            "$ref": "#/components/schemas/ErrorResponse"
          }
        }
      },
      "description": "Invalid Request"
    }
  },
  "summary": "List Project Usage Fields",
  "tags": [
    "subpackage_manage.subpackage_manage/v1.subpackage_manage/v1/projects.subpackage_manage/v1/projects/usage.subpackage_manage/v1/projects/usage/fields"
  ],
  "components": {
    "schemas": {
      "UsageFieldsV1Response": {
        "properties": {
          "features": {
            "description": "API features available to the project",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "models": {
            "description": "List of models available for the project.",
            "items": {
              "$ref": "#/components/schemas/UsageFieldsV1ResponseModelsItems"
            },
            "type": "array"
          },
          "processing_methods": {
            "description": "Processing methods supported by the API",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "tags": {
            "description": "List of tags associated with the project",
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "title": "UsageFieldsV1Response",
        "type": "object"
      },
      "ErrorResponse": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/ErrorResponseTextError"
          },
          {
            "$ref": "#/components/schemas/ErrorResponseLegacyError"
          },
          {
            "$ref": "#/components/schemas/ErrorResponseModernError"
          }
        ],
        "title": "ErrorResponse"
      },
      "UsageFieldsV1ResponseModelsItems": {
        "properties": {
          "language": {
            "description": "The language supported by the model (IETF language tag).",
            "type": "string"
          },
          "model_id": {
            "description": "Unique identifier for the model.",
            "type": "string"
          },
          "name": {
            "description": "Name of the model.",
            "type": "string"
          },
          "version": {
            "description": "Version identifier of the model, typically with a date and a revision number.",
            "type": "string"
          }
        },
        "title": "UsageFieldsV1ResponseModelsItems",
        "type": "object"
      },
      "ErrorResponseTextError": {
        "title": "ErrorResponseTextError",
        "type": "string"
      },
      "ErrorResponseLegacyError": {
        "properties": {
          "err_code": {
            "description": "The error code",
            "type": "string"
          },
          "err_msg": {
            "description": "The error message",
            "type": "string"
          },
          "request_id": {
            "description": "The request ID",
            "type": "string"
          }
        },
        "title": "ErrorResponseLegacyError",
        "type": "object"
      },
      "ErrorResponseModernError": {
        "properties": {
          "category": {
            "description": "The category of the error",
            "type": "string"
          },
          "details": {
            "description": "A description of the error",
            "type": "string"
          },
          "message": {
            "description": "A message about the error",
            "type": "string"
          },
          "request_id": {
            "description": "The unique identifier of the request",
            "type": "string"
          }
        },
        "title": "ErrorResponseModernError",
        "type": "object"
      }
    }
  }
}
