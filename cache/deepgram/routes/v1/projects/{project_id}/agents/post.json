          },
          "metadata": {
            "additionalProperties": {
              "type": "string"
            },
            "description": "Metadata associated with the agent configuration",
            "type": "object"
          }
        },
        "required": [
          "agent_id",
          "config"
        ],
        "title": "CreateAgentConfigurationV1Response",
        "type": "object"
      },
      "ErrorResponse": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/ErrorResponseTextError"
