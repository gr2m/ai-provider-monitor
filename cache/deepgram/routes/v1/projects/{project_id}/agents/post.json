{
  "description": "Creates a new reusable agent configuration. The `config` field must be a valid JSON string representing the `agent` block of a Settings message. The returned `agent_id` can be passed in place of the full `agent` object in future Settings messages.",
  "operationId": "create",
  "parameters": [
    {
      "in": "path",
      "name": "project_id",
      "required": true,
      "schema": {
        "type": "string"
      }
    },
    {
      "description": "Use `Authorization: Token <API_KEY>`\nExample: `Authorization: Token 12345abcdef`\n",
      "in": "header",
      "name": "Authorization",
      "required": true,
      "schema": {
        "type": "string"
      }
    }
  ],
  "requestBody": {
    "content": {
      "application/json": {
        "schema": {
          "$ref": "#/components/schemas/CreateAgentConfigurationV1Request"
        }
      }
    },
    "description": "Agent configuration details"
  },
  "responses": {
    "200": {
      "content": {
        "application/json": {
          "schema": {
            "$ref": "#/components/schemas/CreateAgentConfigurationV1Response"
          }
        }
      },
      "description": "Agent configuration created successfully"
    },
    "400": {
      "content": {
        "application/json": {
          "schema": {
            "$ref": "#/components/schemas/ErrorResponse"
          }
        }
      },
      "description": "Invalid Request"
    }
  },
  "summary": "Create an Agent Configuration",
  "tags": [
    "subpackage_voiceAgent.subpackage_voiceAgent/configurations"
  ],
  "components": {
    "schemas": {
      "CreateAgentConfigurationV1Request": {
        "description": "Request body for creating an agent configuration",
        "properties": {
          "api_version": {
            "default": 1,
            "description": "API version. Defaults to 1",
            "type": "integer"
          },
          "config": {
            "description": "A valid JSON string representing the agent block of a Settings message",
            "type": "string"
          },
          "metadata": {
            "additionalProperties": {
              "type": "string"
            },
            "description": "A map of arbitrary key-value pairs for labeling or organizing the agent configuration",
