            "format": "double",
            "type": "number"
          },
          "text": {
            "type": "string"
          },
          "topics": {
            "items": {
              "$ref": "#/components/schemas/SharedTopicsResultsTopicsSegmentsItemsTopicsItems"
            },
            "type": "array"
          }
        },
        "title": "SharedTopicsResultsTopicsSegmentsItems",
