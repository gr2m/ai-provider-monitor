          }
        },
        "required": [
          "judge_definition"
        ],
        "title": "PostChatCompletionEventJudgingInSchema",
        "type": "object"
      },
      "JudgeOutput": {
        "properties": {
          "analysis": {
            "title": "Analysis",
            "type": "string"
          },
          "answer": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              }
            ],
            "title": "Answer"
          }
        },
        "required": [
          "analysis",
          "answer"
        ],
        "title": "JudgeOutput",
        "type": "object"
      },
      "ObservabilityError": {
