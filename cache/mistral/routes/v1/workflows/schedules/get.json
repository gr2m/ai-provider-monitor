{
  "operationId": "get_schedules_v1_workflows_schedules_get",
  "responses": {
    "200": {
      "content": {
        "application/json": {
          "schema": {
            "$ref": "#/components/schemas/WorkflowScheduleListResponse"
          }
        }
      },
      "description": "Successful Response"
    }
  },
  "summary": "Get Schedules",
  "tags": [
    "workflows.schedules"
  ],
  "components": {
    "schemas": {
      "WorkflowScheduleListResponse": {
        "properties": {
          "schedules": {
            "description": "A list of workflow schedules",
            "items": {
              "$ref": "#/components/schemas/ScheduleDefinitionOutput"
            },
            "title": "Schedules",
            "type": "array"
          }
        },
        "required": [
          "schedules"
        ],
        "title": "WorkflowScheduleListResponse",
        "type": "object"
      },
      "ScheduleDefinitionOutput": {
        "description": "Output representation of a schedule with required schedule_id.\n\nUsed when returning schedules from the API where schedule_id is always present.",
        "properties": {
          "calendars": {
            "description": "Calendar-based specification of times.",
            "items": {
              "$ref": "#/components/schemas/ScheduleCalendar"
            },
            "title": "Calendars",
            "type": "array"
          },
          "cron_expressions": {
            "description": "Cron-based specification of times.",
            "items": {
              "type": "string"
            },
            "title": "Cron Expressions",
            "type": "array"
          },
          "end_at": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Time after which no more actions will be run.",
            "title": "End At"
          },
          "input": {
            "description": "Input to provide to the workflow when starting it.",
            "title": "Input"
          },
          "intervals": {
            "description": "Interval-based specification of times.",
            "items": {
              "$ref": "#/components/schemas/ScheduleInterval"
            },
            "title": "Intervals",
            "type": "array"
          },
          "jitter": {
            "anyOf": [
              {
                "format": "duration",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Jitter to apply each action.\n\nAn action's scheduled time will be incremented by a random value between 0\nand this value if present (but not past the next schedule).\n",
            "title": "Jitter"
          },
          "policy": {
            "$ref": "#/components/schemas/SchedulePolicy",
            "description": "Policy for the schedule."
          },
          "schedule_id": {
            "description": "Unique identifier for the schedule.",
            "title": "Schedule Id",
            "type": "string"
          },
          "skip": {
            "description": "Set of calendar times to skip.",
            "items": {
              "$ref": "#/components/schemas/ScheduleCalendar"
            },
            "title": "Skip",
            "type": "array"
          },
          "start_at": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Time after which the first action may be run.",
            "title": "Start At"
          },
          "time_zone_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "IANA time zone name, for example ``US/Central``.",
            "title": "Time Zone Name"
          }
        },
        "required": [
          "input",
          "schedule_id"
        ],
        "title": "ScheduleDefinitionOutput",
        "type": "object"
      },
      "ScheduleCalendar": {
        "properties": {
          "comment": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Comment"
          },
          "day_of_month": {
            "default": [
              {
                "end": 31,
                "start": 1,
                "step": 0
              }
            ],
            "items": {
              "$ref": "#/components/schemas/ScheduleRange"
            },
            "title": "Day Of Month",
            "type": "array"
          },
          "day_of_week": {
            "default": [
              {
                "end": 6,
                "start": 0,
                "step": 0
              }
            ],
            "items": {
              "$ref": "#/components/schemas/ScheduleRange"
            },
            "title": "Day Of Week",
            "type": "array"
          },
          "hour": {
            "default": [
              {
                "end": 0,
                "start": 0,
                "step": 0
              }
            ],
            "items": {
              "$ref": "#/components/schemas/ScheduleRange"
            },
            "title": "Hour",
            "type": "array"
          },
          "minute": {
            "default": [
              {
                "end": 0,
                "start": 0,
                "step": 0
              }
            ],
            "items": {
              "$ref": "#/components/schemas/ScheduleRange"
            },
            "title": "Minute",
            "type": "array"
          },
          "month": {
            "default": [
              {
                "end": 12,
                "start": 1,
                "step": 0
              }
            ],
            "items": {
              "$ref": "#/components/schemas/ScheduleRange"
            },
            "title": "Month",
            "type": "array"
          },
          "second": {
            "default": [
              {
                "end": 0,
                "start": 0,
                "step": 0
              }
            ],
            "items": {
              "$ref": "#/components/schemas/ScheduleRange"
            },
            "title": "Second",
            "type": "array"
          },
          "year": {
            "default": [],
            "items": {
              "$ref": "#/components/schemas/ScheduleRange"
            },
            "title": "Year",
            "type": "array"
          }
        },
        "title": "ScheduleCalendar",
        "type": "object"
      },
      "ScheduleInterval": {
        "properties": {
          "every": {
            "format": "duration",
            "title": "Every",
            "type": "string"
          },
          "offset": {
            "anyOf": [
              {
                "format": "duration",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Offset"
          }
        },
        "required": [
          "every"
        ],
        "title": "ScheduleInterval",
        "type": "object"
      },
      "SchedulePolicy": {
        "properties": {
          "catchup_window_seconds": {
            "default": 31536000,
            "description": "After a Temporal server is unavailable, amount of time in seconds in the past to execute missed actions.",
            "title": "Catchup Window Seconds",
            "type": "integer"
          },
          "overlap": {
            "$ref": "#/components/schemas/ScheduleOverlapPolicy",
            "default": 1,
            "description": "Policy controlling what to do when a workflow is already running."
          },
          "pause_on_failure": {
            "default": false,
            "description": "Whether to pause the schedule after a workflow failure.",
            "title": "Pause On Failure",
            "type": "boolean"
          }
        },
        "title": "SchedulePolicy",
        "type": "object"
      },
      "ScheduleRange": {
        "properties": {
          "end": {
            "default": 0,
            "title": "End",
            "type": "integer"
          },
          "start": {
            "title": "Start",
            "type": "integer"
          },
          "step": {
            "default": 0,
            "title": "Step",
            "type": "integer"
          }
        },
        "required": [
          "start"
        ],
        "title": "ScheduleRange",
        "type": "object"
      },
      "ScheduleOverlapPolicy": {
        "description": "Controls what happens when a workflow would be started by a schedule but\none is already running.",
        "enum": [
          1,
          2,
          3,
          4,
          5,
          6
        ],
        "title": "ScheduleOverlapPolicy",
        "type": "integer"
      }
    }
  }
}
