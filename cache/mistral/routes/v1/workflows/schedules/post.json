{
  "operationId": "schedule_workflow_v1_workflows_schedules_post",
  "requestBody": {
    "content": {
      "application/json": {
        "schema": {
          "$ref": "#/components/schemas/WorkflowScheduleRequest"
        }
      }
    },
    "required": true
  },
  "responses": {
    "201": {
      "content": {
        "application/json": {
          "schema": {
            "$ref": "#/components/schemas/WorkflowScheduleResponse"
          }
        }
      },
      "description": "Successful Response"
    },
    "422": {
      "content": {
        "application/json": {
          "schema": {
            "$ref": "#/components/schemas/HTTPValidationError"
          }
        }
      },
      "description": "Validation Error"
    }
  },
  "summary": "Schedule Workflow",
  "tags": [
    "beta.workflows.schedules"
  ],
  "components": {
    "schemas": {
      "WorkflowScheduleRequest": {
        "properties": {
          "deployment_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Name of the deployment to route this schedule to",
            "title": "Deployment Name"
          },
          "schedule": {
            "$ref": "#/components/schemas/ScheduleDefinition",
            "description": "The schedule definition"
          },
          "schedule_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Allows you to specify a custom schedule ID. If not provided, a random ID will be generated.",
            "title": "Schedule Id"
          },
          "workflow_identifier": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "The name or ID of the workflow to schedule",
            "title": "Workflow Identifier"
          },
          "workflow_registration_id": {
            "anyOf": [
              {
                "format": "uuid",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "The ID of the workflow registration to schedule",
            "title": "Workflow Registration Id"
          },
          "workflow_task_queue": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "deprecated": true,
            "description": "Deprecated. Use deployment_name instead.",
            "title": "Workflow Task Queue"
          },
          "workflow_version_id": {
            "anyOf": [
              {
                "format": "uuid",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Deprecated: use workflow_registration_id",
            "title": "Workflow Version Id"
          }
        },
        "required": [
          "schedule"
        ],
        "title": "WorkflowScheduleRequest",
        "type": "object"
      },
      "WorkflowScheduleResponse": {
        "properties": {
          "schedule_id": {
            "description": "The ID of the schedule",
            "title": "Schedule Id",
            "type": "string"
          }
        },
        "required": [
          "schedule_id"
        ],
        "title": "WorkflowScheduleResponse",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "ScheduleDefinition": {
        "description": "Specification of the times scheduled actions may occur.\n\nThe times are the union of :py:attr:`calendars`, :py:attr:`intervals`, and\n:py:attr:`cron_expressions` excluding anything in :py:attr:`skip`.\n\nUsed for input where schedule_id is optional (can be provided or auto-generated).",
        "properties": {
          "calendars": {
            "description": "Calendar-based specification of times.",
            "items": {
              "$ref": "#/components/schemas/ScheduleCalendar"
            },
            "title": "Calendars",
            "type": "array"
          },
          "cron_expressions": {
            "description": "Cron-based specification of times.",
            "items": {
              "type": "string"
            },
            "title": "Cron Expressions",
            "type": "array"
          },
          "end_at": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Time after which no more actions will be run.",
            "title": "End At"
          },
          "input": {
            "description": "Input to provide to the workflow when starting it.",
            "title": "Input"
          },
          "intervals": {
            "description": "Interval-based specification of times.",
            "items": {
              "$ref": "#/components/schemas/ScheduleInterval"
            },
            "title": "Intervals",
            "type": "array"
          },
          "jitter": {
            "anyOf": [
              {
                "format": "duration",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Jitter to apply each action.\n\nAn action's scheduled time will be incremented by a random value between 0\nand this value if present (but not past the next schedule).\n",
            "title": "Jitter"
          },
          "policy": {
            "$ref": "#/components/schemas/SchedulePolicy",
            "description": "Policy for the schedule."
          },
          "schedule_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Unique identifier for the schedule.",
            "title": "Schedule Id"
          },
          "skip": {
            "description": "Set of calendar times to skip.",
            "items": {
              "$ref": "#/components/schemas/ScheduleCalendar"
            },
            "title": "Skip",
            "type": "array"
          },
          "start_at": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Time after which the first action may be run.",
            "title": "Start At"
          },
          "time_zone_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "IANA time zone name, for example ``US/Central``.",
            "title": "Time Zone Name"
          }
        },
        "required": [
          "input"
        ],
        "title": "ScheduleDefinition",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      },
      "ScheduleCalendar": {
        "properties": {
          "comment": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Comment"
          },
          "day_of_month": {
            "default": [
              {
                "end": 31,
                "start": 1,
                "step": 0
              }
            ],
            "items": {
              "$ref": "#/components/schemas/ScheduleRange"
            },
            "title": "Day Of Month",
            "type": "array"
          },
          "day_of_week": {
            "default": [
              {
                "end": 6,
                "start": 0,
                "step": 0
              }
            ],
            "items": {
              "$ref": "#/components/schemas/ScheduleRange"
            },
            "title": "Day Of Week",
            "type": "array"
          },
          "hour": {
            "default": [
              {
                "end": 0,
                "start": 0,
                "step": 0
              }
            ],
            "items": {
              "$ref": "#/components/schemas/ScheduleRange"
            },
            "title": "Hour",
            "type": "array"
          },
          "minute": {
            "default": [
              {
                "end": 0,
                "start": 0,
                "step": 0
              }
            ],
            "items": {
              "$ref": "#/components/schemas/ScheduleRange"
            },
            "title": "Minute",
            "type": "array"
          },
          "month": {
            "default": [
              {
                "end": 12,
                "start": 1,
                "step": 0
              }
            ],
            "items": {
              "$ref": "#/components/schemas/ScheduleRange"
            },
            "title": "Month",
            "type": "array"
          },
          "second": {
            "default": [
              {
                "end": 0,
                "start": 0,
                "step": 0
              }
            ],
            "items": {
              "$ref": "#/components/schemas/ScheduleRange"
            },
            "title": "Second",
            "type": "array"
          },
          "year": {
            "default": [],
            "items": {
              "$ref": "#/components/schemas/ScheduleRange"
            },
            "title": "Year",
            "type": "array"
          }
        },
        "title": "ScheduleCalendar",
        "type": "object"
      },
      "ScheduleInterval": {
        "properties": {
          "every": {
            "format": "duration",
            "title": "Every",
            "type": "string"
          },
          "offset": {
            "anyOf": [
              {
                "format": "duration",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Offset"
          }
        },
        "required": [
          "every"
        ],
        "title": "ScheduleInterval",
        "type": "object"
      },
      "SchedulePolicy": {
        "properties": {
          "catchup_window_seconds": {
            "default": 31536000,
            "description": "After a Temporal server is unavailable, amount of time in seconds in the past to execute missed actions.",
            "title": "Catchup Window Seconds",
            "type": "integer"
          },
          "overlap": {
            "$ref": "#/components/schemas/ScheduleOverlapPolicy",
            "default": 1,
            "description": "Policy controlling what to do when a workflow is already running."
          },
          "pause_on_failure": {
            "default": false,
            "description": "Whether to pause the schedule after a workflow failure.",
            "title": "Pause On Failure",
            "type": "boolean"
          }
        },
        "title": "SchedulePolicy",
        "type": "object"
      },
      "ScheduleRange": {
        "properties": {
          "end": {
            "default": 0,
            "title": "End",
            "type": "integer"
          },
          "start": {
            "title": "Start",
            "type": "integer"
          },
          "step": {
            "default": 0,
            "title": "Step",
            "type": "integer"
          }
        },
        "required": [
          "start"
        ],
        "title": "ScheduleRange",
        "type": "object"
      },
      "ScheduleOverlapPolicy": {
        "description": "Controls what happens when a workflow would be started by a schedule but\none is already running.",
        "enum": [
          1,
          2,
          3,
          4,
          5,
          6
        ],
        "title": "ScheduleOverlapPolicy",
        "type": "integer"
      }
    }
  }
}
