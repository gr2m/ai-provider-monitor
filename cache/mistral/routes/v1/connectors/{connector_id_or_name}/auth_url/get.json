{
  "description": "Get the OAuth2 authorization URL for a connector to initiate user authentication.",
  "operationId": "connector_get_auth_url_v1",
  "parameters": [
    {
      "in": "query",
      "name": "app_return_url",
      "required": false,
      "schema": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "title": "App Return Url"
      }
    },
    {
      "in": "path",
      "name": "connector_id_or_name",
      "required": true,
      "schema": {
        "title": "Connector Id Or Name",
        "type": "string"
      }
    }
  ],
  "responses": {
    "200": {
      "content": {
        "application/json": {
          "schema": {
            "$ref": "#/components/schemas/AuthUrlResponse"
          }
        }
      },
      "description": "Successful Response"
    },
    "422": {
      "content": {
        "application/json": {
          "schema": {
            "$ref": "#/components/schemas/HTTPValidationError"
          }
        }
      },
      "description": "Validation Error"
    }
  },
  "summary": "Get the auth URL for a connector.",
  "tags": [
    "beta.connectors"
  ],
  "components": {
    "schemas": {
      "AuthUrlResponse": {
        "properties": {
          "auth_url": {
            "title": "Auth Url",
            "type": "string"
          },
          "ttl": {
            "title": "Ttl",
            "type": "integer"
          }
        },
        "required": [
          "auth_url",
          "ttl"
